document.body.innerHTML = `
  <button id="terraria" style="
    padding: 15px 20px;
    font-size: 18px;
    background: black;
    color: white;
    border: none;
    cursor: pointer;
  ">
    Play Terraria
  </button>
`;

document.getElementById("terraria").onclick = () => {
  const win = window.open("about:blank", "_blank");

  win.document.write(`
    <!DOCTYPE html>
    <html>
    <head>
      <title>Terraria</title>
      <style>
        html, body {
          margin: 0;
          height: 100%;
          overflow: hidden;
        }
        iframe {
          width: 100%;
          height: 100%;
          border: none;
        }
      </style>
    </head>
    <body>
      <iframe src="https://degloved.net/gms/Terraria/"></iframe>
    </body>
    </html>
  `);

  win.document.close();
};
