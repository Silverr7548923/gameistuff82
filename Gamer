document.body.innerHTML = `
  <button id="terraria">Play Terraria</button>
`;

document.getElementById("terraria").onclick = () => {
  const win = window.open("about:blank", "_blank");

  win.document.write(`
    <iframe
      src="https://degloved.net/gms/Terraria/"
      style="width:100vw;height:100vh;border:none;"
    ></iframe>
  `);

  win.document.close();
};
